{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "ignorePaths": [
    // the following components are used to test the behavior of OBI with legacy versions of libraries
    // so we don't want to get them updated
    "internal/test/integration/components/testserver_1.17",
    "internal/test/integration/components/old_grpc",
    // github.com/Shopify/sarama has been moved to github.com/IBM/sarama
    // but we keep supporting the go-offsets for the outdated library, which must not
    // be updated.
    "configs/offsets/shopify/**",
    "NOTICES/**"
  ],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 3,
  "allowedCommands": [
    "make go-mod-tidy",
    "make go-notices-update",
    "make java-notices-update"
  ],
  "packageRules": [
    {
      "groupName": "Go",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch", "digest", "minor", "major"],
      "schedule": ["before 6am on Monday"],
      "postUpgradeTasks": {
        "commands": [
          "make go-mod-tidy",
          "make go-notices-update"
        ],
        "executionMode": "branch"
      }
    },
    {
      "groupName": "Docker",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["patch", "digest", "minor", "major"],
      "schedule": ["before 6am on Tuesday"]
    },
    {
      "groupName": "Github Actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "digest", "minor", "major"],
      "schedule": ["before 6am on Wednesday"]
    },
    {
      "groupName": "Java",
      "matchManagers": ["gradle", "maven"],
      "matchUpdateTypes": ["patch", "digest", "minor", "major"],
      "schedule": ["before 6am on Thursday"],
      "postUpgradeTasks": {
        "commands": [
          "make java-notices-update"
        ],
        "executionMode": "branch"
      }
    },
    {
      "groupName": "NPM",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "digest", "minor", "major"],
      "schedule": ["before 6am on Thursday"]
    },
    {
      "groupName": "Rust",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch", "digest", "minor", "major"],
      "schedule": ["before 6am on Thursday"]
    },
    {
      "description": "Disable patch updates for test dependencies (only bump major/minor)",
      "matchFileNames": ["internal/test/**"],
      "matchUpdateTypes": ["patch", "digest"],
      "enabled": false
    },
    {
      "description": "Disable Go 1.17 testserver updates",
      "matchFileNames": ["internal/test/integration/components/testserver_1.17"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["golang"],
      "enabled": false
    },
    {
      "description": "Block Spring Boot major upgrades for JDK8 example (Spring Boot 3+ requires JDK 17+)",
      "matchFileNames": ["internal/test/integration/components/java_tls/jdk8/pom.xml"],
      "matchManagers": ["maven"],
      "matchPackageNames": ["org.springframework.boot:spring-boot-starter-parent", "org.springframework.boot:spring-boot-dependencies", "org.springframework.boot:spring-boot-maven-plugin"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Block kafka-clients major upgrades for javakafka test component",
      "matchFileNames": ["internal/test/integration/components/javakafka/pom.xml"],
      "matchManagers": ["maven"],
      "matchPackageNames": ["org.apache.kafka:kafka-clients"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Block Spring Boot major upgrades for javatestserver (requires manual evaluation)",
      "matchFileNames": ["internal/test/integration/components/javatestserver/pom.xml"],
      "matchManagers": ["maven"],
      "matchPackageNames": ["org.springframework.boot:spring-boot-starter-parent", "org.springframework.boot:spring-boot-dependencies", "org.springframework.boot:spring-boot-maven-plugin"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Block JUnit major upgrades for the Java agent (JUnit 6 requires Java 17+)",
      "matchFileNames": ["pkg/internal/java/agent/build.gradle.kts"],
      "matchManagers": ["gradle"],
      "matchPackageNames": ["org.junit.jupiter:junit-jupiter-api", "org.junit.jupiter:junit-jupiter-engine", "org.junit.platform:junit-platform-launcher"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Block Spring Boot major upgrades for sync_async_tls (requires manual evaluation)",
      "matchFileNames": ["internal/test/integration/components/java_tls/sync_async_tls/pom.xml"],
      "matchManagers": ["maven"],
      "matchPackageNames": ["org.springframework.boot:spring-boot-starter-parent", "org.springframework.boot:spring-boot-dependencies", "org.springframework.boot:spring-boot-maven-plugin"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Block Spring Boot major upgrades for netty_tls (requires manual evaluation)",
      "matchFileNames": ["internal/test/integration/components/java_tls/netty_tls/pom.xml"],
      "matchManagers": ["maven"],
      "matchPackageNames": ["org.springframework.boot:spring-boot-starter-parent"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ],
  "labels": [
    "dependencies"
  ]
}
